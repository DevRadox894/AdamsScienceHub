@model AdamsScienceHub.Models.Material
@{
    ViewData["Title"] = Model.TopicTitle;
    var siblings = ViewBag.Siblings as List<AdamsScienceHub.Models.Material>;
    var index = (int)ViewBag.Index;
}

<div class="container py-4">
    <!-- Back button -->
    <div class="mb-3">
        <a asp-controller="Subjects" asp-action="Explore" asp-route-id="@Model.SubjectId" class="btn btn-secondary">
            &larr; Back to Topics
        </a>
    </div>

    <!-- Title + Prev/Next buttons -->
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <div>
            <strong>@Model.TopicTitle</strong>
            <div class="small text-muted">Material @(index + 1) of @((siblings?.Count ?? 1))</div>
        </div>
    </div>

    <div class="row">
        <!-- PDF Viewer -->
        <div class="col-12 col-lg-9 mb-3">

            <div class="pagination mb-2 d-flex align-items-center gap-2" style="font-size: 12px;">
                <button type="button" class="btn btn-outline-primary" id="prevBtn" onclick="changePage(-1)">Previous</button>
                <span>Page <span id="pageInfo"></span></span>
                <button type="button" class="btn btn-outline-primary" id="nextBtn" onclick="changePage(1)">Next</button>
            </div>

               <canvas id="pdf-render" style="border:1px solid #ccc; width:100%;"></canvas>
        </div>

        <!-- Video Card -->
        <div class="col-12 col-lg-3">
            @if (!string.IsNullOrEmpty(Model.VideoUrl))
            {
                <div class="card p-3 mb-3 dashboard-card">
                    <h5>Watch Lesson Video</h5>
                    <p class="small text-muted">Embedded YouTube lesson</p>
                    <div class="ratio ratio-16x9">
                        @{
                            string videoUrl = Model.VideoUrl;

                            if (videoUrl.Contains("watch?v="))
                            {
                                // Convert full YouTube URL to embed
                                videoUrl = videoUrl.Replace("watch?v=", "embed/");
                            }
                            else if (videoUrl.Contains("youtu.be/"))
                            {
                                // Convert short YouTube URL to embed
                                var id = videoUrl.Split("/").Last().Split("?").First();
                                videoUrl = $"https://www.youtube.com/embed/{id}";
                            }
                        }
                        <iframe src="@videoUrl" title="Lesson Video" allowfullscreen></iframe>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.7.107/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.7.107/pdf.worker.min.js"></script>

    <script>
        // 🔥 Use Cloudinary URL directly
        const url = '@Model.FilePath';

        let pdfDoc = null, pageNum = 1, pageCount = 0;
        const canvas = document.getElementById('pdf-render');
        const ctx = canvas.getContext('2d');

        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.7.107/pdf.worker.min.js';

        pdfjsLib.getDocument(url).promise.then(doc => {
            pdfDoc = doc;
            pageCount = doc.numPages;
            document.getElementById('page-count').textContent = pageCount;
            renderPage(pageNum);
        }).catch(err => {
            console.error('Error loading PDF:', err);
            alert('Failed to load PDF. Make sure the URL is public.');
        });

                   function renderPage(num) {
            pdfDoc.getPage(num).then(page => {

                const containerWidth = canvas.parentElement.clientWidth;
                const baseViewport = page.getViewport({ scale: 1 });

                // Fit width
                let scale = containerWidth / baseViewport.width;

                // 🔥 Boost zoom for mobile
                if (window.innerWidth < 768) {
                    scale *= 1.4;   // increase if you want bigger (1.5 or 1.6)
                }

                const viewport = page.getViewport({ scale: scale });

                // 🔥 Retina sharp rendering
                const outputScale = window.devicePixelRatio || 1;

                canvas.width = viewport.width * outputScale;
                canvas.height = viewport.height * outputScale;

                canvas.style.width = viewport.width + "px";
                canvas.style.height = viewport.height + "px";

                ctx.setTransform(outputScale, 0, 0, outputScale, 0, 0);

                const renderCtx = {
                    canvasContext: ctx,
                    viewport: viewport
                };

                page.render(renderCtx);

                document.getElementById('page-num').textContent = num;
            });
        }

        document.getElementById('prev-page').addEventListener('click', () => {
            if (pageNum <= 1) return;
            pageNum--;
            renderPage(pageNum);
        });

        document.getElementById('next-page').addEventListener('click', () => {
            if (pageNum >= pageCount) return;
            pageNum++;
            renderPage(pageNum);
        });

        window.addEventListener('resize', () => renderPage(pageNum));
    </script>
}